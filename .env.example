# Kotak Neo API Credentials Template
# Get your Consumer Key from the Trade API card in Kotak Neo portal
KOTAK_CONSUMER_KEY=your_consumer_key_here

# Your registered mobile number (typically 10 digits or with country code, e.g., 9876543210)
KOTAK_MOBILE=your_mobile_number_here

# Your Unique Client Code (UCC)
KOTAK_UCC=your_ucc_here

# Your 6-digit MPIN for trading validation
KOTAK_MPIN=your_mpin_here

# (Optional) TOTP Secret Key for automated 2FA login.
# If left blank, you will be prompted to enter the 6-digit TOTP manually in the UI.
KOTAK_TOTP_SECRET=your_totp_secret_key_here
